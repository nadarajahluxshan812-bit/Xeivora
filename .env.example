OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=
OLLAMA_MODEL=
PERPLEXITY_API_KEY=
OPENWEATHER_API_KEY=
AIRALO_API_KEY=
EXCHANGERATE_API_KEY=

OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_MODEL=gemini-2.5-flash
PROVIDER_TIMEOUT_MS=15000
PROVIDER_STREAM_IDLE_TIMEOUT_MS=15000

# PostgreSQL 18 persistence. If this is empty, Xeivora falls back to local JSON storage.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/xeivora
DATABASE_POOL_MAX=10
DATABASE_SSL=false
