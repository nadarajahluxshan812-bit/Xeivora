# Xeivora environment template — copy to .env.local and fill in.
# Do not commit real secrets. See DEPLOYMENT.md for the full production checklist.
#
# Note: the code does NOT use AUTH_SECRET (sessions are opaque hashed tokens)
# or GOOGLE_GENERATIVE_AI_API_KEY (use GEMINI_API_KEY).

# ─────────────────────────────────────────────
# Required for production
# ─────────────────────────────────────────────

# Postgres persistence. If empty, Xeivora falls back to local JSON storage
# (dev only — not safe on serverless/ephemeral filesystems).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/xeivora
DATABASE_SSL=true
DATABASE_POOL_MAX=10

# Public origin — used for OAuth redirects and Stripe return URLs.
NEXT_PUBLIC_APP_URL=https://your-domain.com

# AI providers (Gemini key is GEMINI_API_KEY; GOOGLE_API_KEY is an optional fallback).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Google OAuth (for "Continue with Google" login + Drive/Gmail integrations).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub integration (repo tab). OAuth callback: <APP_URL>/api/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Encrypts stored integration OAuth tokens. Set a fixed random value and never
# rotate it without re-linking integrations (see DEPLOYMENT.md).
INTEGRATIONS_ENCRYPTION_KEY=

# Vercel deployments (Deployments tab). VERCEL_TEAM_ID is optional (team scope).
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Stripe billing. Webhook endpoint: <APP_URL>/api/stripe/webhook
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────

# Provider model overrides + timeouts
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_MODEL=gemini-2.5-flash
PROVIDER_TIMEOUT_MS=15000
PROVIDER_STREAM_IDLE_TIMEOUT_MS=15000

# Local models (Ollama)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=
OLLAMA_MODEL=

# Tool providers
PERPLEXITY_API_KEY=
OPENWEATHER_API_KEY=
AIRALO_API_KEY=
EXCHANGERATE_API_KEY=

# Additional OAuth integrations
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
