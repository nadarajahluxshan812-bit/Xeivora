{
  "name": "xeivora",
  "version": "0.1.0",
  "private": true,
  "description": "Xeivora desktop and web AI workspace for continuity, memory, and orchestration.",
  "author": "Xeivora Ltd",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder --dir",
    "electron:dist": "electron-builder --mac",
    "electron:dist:all": "electron-builder --mac --win",
    "lint": "eslint app components lib scripts db.ts instrumentation.ts next.config.mjs tailwind.config.ts postcss.config.mjs server.js",
    "check:env": "node scripts/check-env.js"
  },
  "build": {
    "appId": "com.xeivora.app",
    "productName": "Xeivora",
    "copyright": "Copyright 2026 Xeivora Ltd",
    "directories": {
      "output": "dist",
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "electron/assets/icon.png",
      "target": [
        "AppImage"
      ]
    },
    "dmg": {
      "title": "Install Xeivora",
      "backgroundColor": "#0e0b08"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@stripe/stripe-js": "^9.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-is-dev": "^3.0.1",
    "electron-store": "^11.0.2",
    "express": "^5.1.0",
    "framer-motion": "^12.23.12",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "next": "^15.5.2",
    "openai": "^6.41.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.0",
    "cross-env": "^10.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "wait-on": "^9.0.10"
  }
}
